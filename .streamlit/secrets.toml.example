# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit credentials.
#
# On Streamlit Cloud: paste these key=value pairs directly into the
# "Secrets" section of your app settings (no file needed there).

# Supabase PostgreSQL — one project per broker backend.
# db_url is selected automatically based on BROKER_BACKEND (see core/config.py).
#
# IBKR production app secrets (BROKER_BACKEND=ibkr):
#   DATABASE_URL_IBKR = "postgresql://postgres.<ref>:<password>@aws-1-eu-central-2.pooler.supabase.com:5432/postgres"
#
# T212 staging app secrets (BROKER_BACKEND=t212):
#   DATABASE_URL_T212 = "postgresql://postgres.<ref>:<password>@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"
#
# Generic fallback (used when neither specific var is set):
DATABASE_URL = "postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Broker backend — controls which DB URL and which live-data panels are shown.
# "ibkr" → DATABASE_URL_IBKR  |  "t212" → DATABASE_URL_T212  |  "mock" → DATABASE_URL
BROKER_BACKEND = "t212"

# Trading 212 API credentials (generated in T212 app → Settings → API).
# Practice account (demo.trading212.com):
T212_API_KEY_PAPER = ""
T212_API_SECRET_PAPER = ""
# Live Invest account (live.trading212.com) — leave blank until ready:
T212_API_KEY_LIVE = ""
T212_API_SECRET_LIVE = ""
T212_DEMO = "1"
