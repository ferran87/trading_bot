# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit credentials.
#
# On Streamlit Cloud: paste these key=value pairs directly into the
# "Secrets" section of your app settings (no file needed there).

# Supabase PostgreSQL.  Selected automatically based on BROKER_BACKEND (see
# core/config.py):
#   "t212" → DATABASE_URL_T212  |  anything else → DATABASE_URL (generic fallback)
DATABASE_URL_T212 = "postgresql://postgres.<ref>:<password>@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"
DATABASE_URL      = "postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Broker backend.
BROKER_BACKEND = "t212"

# Trading 212 API credentials (generated in T212 app → Settings → API).
# Single-account defaults.
T212_API_KEY_PAPER    = ""
T212_API_SECRET_PAPER = ""
T212_API_KEY_LIVE     = ""
T212_API_SECRET_LIVE  = ""

# Per-owner overrides (optional). When a bot's owner is "Antonio" these win
# over the defaults above.  Add a block per additional owner.
# T212_API_KEY_PAPER_ANTONIO    = ""
# T212_API_SECRET_PAPER_ANTONIO = ""
# T212_API_KEY_LIVE_ANTONIO     = ""
# T212_API_SECRET_LIVE_ANTONIO  = ""

# Anthropic — used by the AI agents (trade_explainer, strategy_critic,
# portfolio_manager, strategist).
ANTHROPIC_API_KEY = "sk-ant-..."
