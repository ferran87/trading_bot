# Copy to .env and fill in — .env is gitignored.

# Anthropic (used by the AI agents: trade_explainer, strategy_critic,
# portfolio_manager, strategist).
ANTHROPIC_API_KEY=sk-ant-...

# Trading 212 — single-account setup (default keys, used when no per-owner
# variant is set).
T212_API_KEY_PAPER=...
T212_API_SECRET_PAPER=...
T212_API_KEY_LIVE=...
T212_API_SECRET_LIVE=...

# Trading 212 — per-owner keys (optional). When a bot's owner is "Antonio"
# and these are set, they override the generic _PAPER / _LIVE keys above.
# T212_API_KEY_PAPER_ANTONIO=...
# T212_API_SECRET_PAPER_ANTONIO=...
# T212_API_KEY_LIVE_ANTONIO=...
# T212_API_SECRET_LIVE_ANTONIO=...

# Which broker backend to use: "mock" | "t212"
BROKER_BACKEND=t212

# Database (optional). Defaults to local SQLite at data/trades.db.
# DATABASE_URL_T212=postgresql://...    # used when BROKER_BACKEND=t212
# DATABASE_URL=postgresql://...         # generic fallback (Streamlit Cloud)
