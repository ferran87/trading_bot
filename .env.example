# Copy to .env and fill in — .env is gitignored.

# Anthropic (used from Phase 3 onward for Bot 3 sentiment scoring)
ANTHROPIC_API_KEY=sk-ant-...

# IBKR paper trading (used once Phase 1 switches from MockBroker to IBKRBroker)
# IB Gateway / TWS must be running on the host:port below.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497            # 7497 = TWS paper, 4002 = Gateway paper
IBKR_CLIENT_ID_BASE=100   # bots get base+bot_id: 101, 102, 103
# Seconds to wait for a MKT fill (paper can be slow; EU ETFs need RTH).
# IBKR_ORDER_TIMEOUT_SEC=120

# Which broker backend to use: "mock" | "ibkr"
BROKER_BACKEND=mock
